# Environment variables
export EDITOR=nvim
export VISUAL=nvim

# Directory navigation aliases
alias home='cd "$HOME"'
alias dl='cd "$HOME/Downloads"'
alias doc='cd "$HOME/Documents"'
alias config='cd "$HOME/.config"'
alias nixconfig='cd "/etc/nixos"'
alias edu='cd "$HOME/edu"'
alias web='cd "$HOME/edu/web/CS3220_ide/workspace/"'
alias para='cd "$HOME/edu/paradigms/class_material/"'
alias algo='cd "$HOME/edu/algorithms/class_material/"'
export PATH="$HOME/.local/bin:$PATH"
