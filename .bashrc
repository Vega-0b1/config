# Environment variables
export EDITOR=nvim
export VISUAL=nvim

# Directory navigation aliases
alias home='cd "$HOME"'
alias dl='cd "$HOME/Downloads"'
alias doc='cd "$HOME/Documents"'
alias config='cd "$HOME/.config"'
alias nixconfig='cd "/etc/nixos"'
alias edu='cd "$HOME/edu"'
alias web='cd "$HOME/edu/zOld/web/CS3220_ide/workspace"'
alias para='cd "$HOME/edu/zOld/paradigms"'
alias algo='cd "$HOME/edu/zOld/algorithms"'
alias net='cd "$HOME/edu/network"'
alias cyber='cd "$HOME/edu/cybersecurity"'
alias soft='cd "$HOME/edu/software_engineering"'
export PATH="$HOME/.local/bin:$PATH"